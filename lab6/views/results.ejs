<!DOCTYPE html>
<html>
<head>
  <title>Results</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">

  <h1>Quotes Found</h1>

  <% if (quotes.length === 0) { %>
    <div class="alert alert-warning">No quotes found.</div>
  <% } %>

  <% for (let q of quotes) { %>
    <div class="card p-3 mb-3">
      <p class="mb-2">"<%= q.quote %>"</p>

      <p>
        —
        <a href="#" class="authorLink" data-id="<%= q.authorId %>">
          <%= q.firstName %> <%= q.lastName %>
        </a>
      </p>

      <p class="mb-0">
        Category: <%= q.category %><br>
        Likes: <%= q.likes %>
      </p>
    </div>
  <% } %>

  <a href="/" class="btn btn-secondary mb-4">Back to Home</a>

  <div class="modal fade" id="authorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Author Information</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body" id="authorInfo"></div>
      </div>
    </div>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/script.js"></script>
</body>
</html>