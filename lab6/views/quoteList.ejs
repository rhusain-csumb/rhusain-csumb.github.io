<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Quote List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
  <h1>Update/Delete Quotes</h1>

  <% if (quotes.length === 0) { %>
    <div class="alert alert-warning">No quotes found.</div>
  <% } %>

  <% for (let q of quotes) { %>
    <div class="card p-3 mb-3">
      <p class="mb-2">"<%= q.quote %>"</p>
      <p class="mb-2"><strong><%= q.firstName %> <%= q.lastName %></strong></p>
      <p class="mb-2">Category: <%= q.category %> | Likes: <%= q.likes %></p>
      <div>
        <a href="/quote/edit?quoteId=<%= q.quoteId %>" class="btn btn-sm btn-primary">Update</a>
        <a href="/quote/delete?quoteId=<%= q.quoteId %>" class="btn btn-sm btn-danger">Delete</a>
      </div>
    </div>
  <% } %>

  <a href="/admin" class="btn btn-secondary">Back to Admin</a>
</div>
</body>
</html>