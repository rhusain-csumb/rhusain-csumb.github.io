<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Author</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
  <h1>Updating Author Data</h1>

  <form method="POST" action="/author/edit">
    <input type="hidden" name="authorId" value="<%= authorInfo[0].authorId %>">

    <div class="mb-3">
      <label class="form-label">First Name</label>
      <input type="text" name="fName" value="<%= authorInfo[0].firstName %>" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Last Name</label>
      <input type="text" name="lName" value="<%= authorInfo[0].lastName %>" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Date of Birth</label>
      <input type="date" name="dob" value="<%= authorInfo[0].dobISO || '' %>" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label">Date of Death</label>
      <input type="date" name="dod" value="<%= authorInfo[0].dodISO || '' %>" class="form-control">
    </div>

    <div class="mb-3">
      <label class="form-label d-block">Sex</label>
      <input type="radio" name="sex" value="M" <% if (authorInfo[0].sex === "M") { %>checked<% } %>> Male
      <input type="radio" name="sex" value="F" class="ms-3" <% if (authorInfo[0].sex === "F") { %>checked<% } %>> Female
    </div>

    <div class="mb-3">
      <label class="form-label">Profession</label>
      <input type="text" name="profession" value="<%= authorInfo[0].profession %>" class="form-control">
    </div>

    <div class="mb-3">
      <label class="form-label">Country</label>
      <input type="text" name="country" value="<%= authorInfo[0].country %>" class="form-control">
    </div>

    <div class="mb-3">
      <label class="form-label">Portrait URL</label>
      <input type="text" name="portrait" value="<%= authorInfo[0].portrait %>" class="form-control">
    </div>

    <div class="mb-3">
      <label class="form-label">Biography</label>
      <textarea name="biography" rows="6" class="form-control"><%= authorInfo[0].biography %></textarea>
    </div>

    <button class="btn btn-primary">Update Author</button>
    <a href="/authors" class="btn btn-secondary">Back to Author List</a>
  </form>
</div>
</body>
</html>