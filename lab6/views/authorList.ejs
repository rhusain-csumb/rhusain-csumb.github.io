<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Author List</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
  <h1>Update/Delete Authors</h1>

  <% if (authors.length === 0) { %>
    <div class="alert alert-warning">No authors found.</div>
  <% } %>

  <% for (let i = 0; i < authors.length; i++) { %>
    <div class="card p-3 mb-3">
      <strong><%= authors[i].firstName %> <%= authors[i].lastName %></strong>
      <div class="mt-2">
        <a href="/author/edit?authorId=<%= authors[i].authorId %>" class="btn btn-sm btn-primary">Update</a>
        <a href="/author/delete?authorId=<%= authors[i].authorId %>" class="btn btn-sm btn-danger">Delete</a>
      </div>
    </div>
  <% } %>

  <a href="/admin" class="btn btn-secondary">Back to Admin</a>
</div>
</body>
</html>