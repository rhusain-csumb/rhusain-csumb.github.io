<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Add Quote</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
  <h1>Adding a New Quote</h1>

  <% if (typeof message !== "undefined") { %>
    <div class="alert alert-success"><%= message %></div>
  <% } %>

  <form method="POST" action="/quote/new">
    <div class="mb-3">
      <label class="form-label">Quote</label>
      <textarea name="quote" rows="4" class="form-control" required></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label">Author</label>
      <select name="authorId" class="form-select" required>
        <% for (let a of authors) { %>
          <option value="<%= a.authorId %>">
            <%= a.firstName %> <%= a.lastName %>
          </option>
        <% } %>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label">Category</label>
      <select name="category" class="form-select" required>
        <% for (let c of categories) { %>
          <option value="<%= c.category %>"><%= c.category %></option>
        <% } %>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label">Likes</label>
      <input type="number" name="likes" class="form-control" value="0" min="0">
    </div>

    <button class="btn btn-primary">Add Quote</button>
    <a href="/admin" class="btn btn-secondary">Back to Admin</a>
  </form>
</div>
</body>
</html>