<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Quote</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">
  <h1>Updating Quote Data</h1>

  <form method="POST" action="/quote/edit">
    <input type="hidden" name="quoteId" value="<%= quoteInfo.quoteId %>">

    <div class="mb-3">
      <label class="form-label">Quote</label>
      <textarea name="quote" rows="4" class="form-control" required><%= quoteInfo.quote %></textarea>
    </div>

    <div class="mb-3">
      <label class="form-label">Author</label>
      <select name="authorId" class="form-select" required>
        <% for (let a of authors) { %>
          <option value="<%= a.authorId %>" <% if (a.authorId === quoteInfo.authorId) { %>selected<% } %>>
            <%= a.firstName %> <%= a.lastName %>
          </option>
        <% } %>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label">Category</label>
      <select name="category" class="form-select" required>
        <% for (let c of categories) { %>
          <option value="<%= c.category %>" <% if (c.category === quoteInfo.category) { %>selected<% } %>>
            <%= c.category %>
          </option>
        <% } %>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label">Likes</label>
      <input type="number" name="likes" class="form-control" min="0" value="<%= quoteInfo.likes %>">
    </div>

    <button class="btn btn-primary">Update Quote</button>
    <a href="/quotes" class="btn btn-secondary">Back to Quote List</a>
  </form>
</div>
</body>
</html>