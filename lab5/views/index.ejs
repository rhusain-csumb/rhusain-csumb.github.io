<!DOCTYPE html>
<html>
<head>
  <title>Quote Finder</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container mt-4">

  <h1>Quote Finder</h1>
  <hr>

  <h3>Keyword</h3>
  <form action="/searchByKeyword" method="GET" class="mb-3">
    <input type="text" name="keyword" class="form-control mb-2" placeholder="Enter keyword">
    <button class="btn btn-primary">Search</button>
  </form>

  <hr>

  <h3>Author</h3>
  <form action="/searchByAuthor" method="GET" class="mb-3">
    <select name="authorId" class="form-select mb-2">
      <% for (let a of authors) { %>
        <option value="<%= a.authorId %>">
          <%= a.firstName %> <%= a.lastName %>
        </option>
      <% } %>
    </select>
    <button class="btn btn-primary">Search</button>
  </form>

  <hr>

  <h3>Category</h3>
  <form action="/searchByCategory" method="GET" class="mb-3">
    <select name="category" class="form-select mb-2">
      <% for (let c of categories) { %>
        <option value="<%= c.category %>">
          <%= c.category %>
        </option>
      <% } %>
    </select>
    <button class="btn btn-primary">Search</button>
  </form>

  <hr>

  <h3>Likes</h3>
  <form action="/searchByLikes" method="GET" class="mb-3">
    <div class="row g-2 mb-2">
      <div class="col">
        <input type="number" name="minLikes" value="0" class="form-control" placeholder="Min likes">
      </div>
      <div class="col">
        <input type="number" name="maxLikes" value="1000" class="form-control" placeholder="Max likes">
      </div>
    </div>
    <button class="btn btn-primary">Search</button>
  </form>

</div>
</body>
</html>