<%- include("partials/header") %>
<%- include("partials/nav") %>

<main class="container">
  <h2>DevOps</h2>
  <p>
    DevOps combines software development and IT operations to improve
    collaboration, automation, and continuous delivery.
  </p>

  <section class="card">
    <h3>Main Goals</h3>
    <ul>
      <li>Faster software delivery</li>
      <li>Better collaboration between teams</li>
      <li>Automation of testing and deployment</li>
      <li>More reliable releases</li>
    </ul>
  </section>

  <section class="card">
    <h3>Programming Joke from a Web API</h3>
    <% if (joke) { %>
      <p><strong><%= joke.setup %></strong></p>
      <p><%= joke.punchline %></p>
    <% } else { %>
      <p><%= error %></p>
    <% } %>
  </section>
</main>

<%- include("partials/footer") %>